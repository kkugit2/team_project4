# 실제 원티드 데이터 사용 여부
# true: real_data의 JSON 파일 사용 (빌드 타임)
# false: /api/wanted/* API 프록시 사용 (Mock 데이터)
NEXT_PUBLIC_USE_REAL_DATA=true

# Supabase Configuration
# Supabase 프로젝트에서 Settings > API Keys에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 자기소개서 분석용 LLM API (선택사항)
# GEMINI_API_KEY=YOUR_GEMINI_KEY
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# 원티드 Open API (선택사항, 현재 mock 사용)
# WANTED_CLIENT_ID=YOUR_CLIENT_ID
# WANTED_CLIENT_SECRET=YOUR_CLIENT_SECRET
